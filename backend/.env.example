DATABASE_URL="postgresql://postgres:postgres@localhost:5432/jobscheduler?schema=public"
REDIS_URL="redis://localhost:6379"
JWT_SECRET="change-this-to-a-long-random-string"
JWT_EXPIRES_IN="24h"
PORT=4000
NODE_ENV=development
CORS_ORIGIN=*

# Optional: enables AI-generated failure summaries (bonus feature).
# Leave blank to disable - the rest of the system works fully without it.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# Worker process settings (used when running `npm run worker`)
API_URL=http://localhost:4000
PROJECT_API_KEY=
WORKER_QUEUES=default
WORKER_CONCURRENCY=5
WORKER_POLL_INTERVAL_MS=1000
WORKER_HEARTBEAT_INTERVAL_MS=5000
WORKER_LEASE_MS=60000
